{
  "compilerOptions": {
    "outDir": "dist",
    "target": "ES2022",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "noEmit": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "types": ["node", "bun"],
    "lib": ["esnext"],
    "paths": {
      "@vine/liff-fixtures/paths": ["../../packages/liff-fixtures/src/paths"]
    }
  },
  "include": [
    "./src",
    "../../packages/zero-schema/src/augment.ts"
  ]
}
