{
  "name": "@vine/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch --env-file=../../.env src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "clean": "rm -rf dist",
    "start": "bun dist/index.js",
    "lint": "oxlint --import-plugin --type-aware",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@better-auth/expo": "^1.3.32",
    "@bufbuild/protobuf": "^2.0.0",
    "@connectrpc/connect": "^2.0.0",
    "@connectrpc/connect-fastify": "^2.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@take-out/better-auth-utils": "^0.2.10",
    "@take-out/helpers": "^0.2.10",
    "@vine/db": "workspace:*",
    "@vine/drive": "workspace:*",
    "@vine/liff-fixtures": "workspace:*",
    "@vine/flex-schema": "workspace:*",
    "@vine/proto": "workspace:*",
    "@vine/richmenu-schema": "workspace:*",
    "@vine/zero-schema": "workspace:*",
    "better-auth": "^1.3.32",
    "drizzle-orm": "1.0.0-beta.9-e89174b",
    "fastify": "^5.8.5",
    "pino": "^10.3.1",
    "on-zero": "0.2.10",
    "valibot": "^1.1.0"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.61.0",
    "@types/bun": "^1.3.12",
    "@types/node": "24.0.3",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
