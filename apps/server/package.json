{
  "name": "@vine/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch --env-file=../../.env src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "clean": "rm -rf dist",
    "start": "bun dist/index.js",
    "lint": "oxlint --import-plugin --type-aware",
    "typecheck": "tsc --noEmit",
    "test": "bun run test:unit",
    "test:unit": "vitest run -c vitest.config.ts",
    "test:integration": "bun -e \"console.error('apps/server test:integration is deprecated. Use root bun scripts/integration.ts for the full clean integration run, or bun run test:integration:db here after starting a clean Docker DB.'); process.exit(1)\"",
    "test:integration:db": "vitest run -c vitest.integration.config.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@better-auth/expo": "^1.6.5",
    "@bufbuild/protobuf": "^2.12.0",
    "@connectrpc/connect": "^2.0.0",
    "@connectrpc/connect-fastify": "^2.0.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "@take-out/better-auth-utils": "^0.2.10",
    "@take-out/helpers": "^0.2.10",
    "@vine/db": "workspace:*",
    "@vine/drive": "workspace:*",
    "@vine/flex-schema": "workspace:*",
    "@vine/imagemap-schema": "workspace:*",
    "@vine/liff-fixtures": "workspace:*",
    "@vine/proto": "workspace:*",
    "@vine/richmenu-schema": "workspace:*",
    "@vine/zero-schema": "workspace:*",
    "better-auth": "^1.6.9",
    "drizzle-orm": "1.0.0-beta.9-e89174b",
    "fastify": "^5.8.5",
    "fflate": "^0.8.2",
    "jose": "^6.2.3",
    "on-zero": "0.2.10",
    "pino": "^10.3.1",
    "valibot": "^1.1.0"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.64.0",
    "@types/bun": "^1.3.13",
    "@types/node": "25.6.0",
    "form-data": "^4.0.5",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
