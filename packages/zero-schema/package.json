{
  "name": "@vine/zero-schema",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./audience/query": "./src/audience/query.ts",
    "./schema": "./src/schema.ts",
    "./models/*": "./src/models/*.ts",
    "./queries/*": "./src/queries/*.ts",
    "./generated/*": "./src/generated/*.ts",
    "./server/*": "./src/server/*.ts"
  },
  "scripts": {
    "build": "mkdir -p dist && touch dist/.build && echo 'zero-schema package - no build step'",
    "dev": "echo 'zero-schema package - no dev step'",
    "test": "vitest run",
    "zero:generate": "on-zero generate src --after 'bun lint:fix'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rocicorp/zero": "1.4.0",
    "@vine/db": "workspace:*",
    "drizzle-orm": "1.0.0-beta.9-e89174b",
    "on-zero": "0.4.4",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
