{
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "target": "ES2022",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "noEmit": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "types": ["node", "bun", "vite/client"],
    "lib": ["esnext"]
  },
  "include": ["src"],
  "exclude": ["**/*.test.ts"]
}
